# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/

# Local/generated reports can be regenerated by the CLI.
# Keep .gitkeep files so directories exist.
reports/*.json
reports/*.md
!reports/.gitkeep

# Generated documentation site can be regenerated by `detectsmith docs`.
site/*.md
site/rules/
!site/.gitkeep
